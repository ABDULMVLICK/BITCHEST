{% extends 'base.html.twig' %}

{% block title %}Forgot Password - BitChest{% endblock %}

{% block body %}
<div class="min-h-screen flex items-center justify-center py-8 px-4">
    <div class="w-full max-w-sm">
        <h1 class="text-2xl font-bold text-center mb-6">Forgot Password</h1>

        {% if sent %}
            <div class="bg-green-50 border border-green-300 text-green-700 px-4 py-3 rounded mb-4">
                If this email is registered, a reset link has been sent.
                Check your inbox (or <a href="http://localhost:8025" class="underline" target="_blank">Mailpit</a> in dev).
            </div>
            <p class="text-center text-sm">
                <a href="{{ path('app_login') }}" class="text-blue-600 hover:underline">Back to login</a>
            </p>
        {% else %}
            <p class="text-gray-600 mb-4 text-sm">
                Enter your email address and we'll send you a link to reset your password.
            </p>
            <form method="post" class="bg-white border border-gray-200 rounded p-6 space-y-4">
                <div>
                    <label class="block font-medium mb-1">Email</label>
                    <input type="email" name="email" required autofocus
                        class="w-full border border-gray-300 rounded px-3 py-2">
                </div>
                <button type="submit"
                    class="w-full bg-blue-600 text-white py-2 rounded hover:bg-blue-700">
                    Send Reset Link
                </button>
            </form>
            <p class="text-center text-sm mt-4">
                <a href="{{ path('app_login') }}" class="text-blue-600 hover:underline">Back to login</a>
            </p>
        {% endif %}
    </div>
</div>
{% endblock %}
