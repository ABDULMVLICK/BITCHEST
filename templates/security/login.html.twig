{% extends 'base.html.twig' %}

{% block title %}Login - BitChest{% endblock %}

{% block body %}
<div class="min-h-screen flex items-center justify-center py-8 px-4 bg-gray-50">
    <div class="w-full max-w-sm animate-fade-in">
        <div class="text-center mb-8">
            <img src="{{ asset('images/bitchest_logo.png') }}" alt="BitChest"
                class="h-16 w-16 mx-auto mb-3 rounded-full shadow">
            <h1 class="text-2xl font-bold text-blue-900">BitChest</h1>
            <p class="text-gray-400 text-sm mt-1">Crypto trading platform</p>
        </div>

        {% for message in app.flashes('success') %}
            <p class="bg-green-50 border border-green-300 text-green-700 px-3 py-2 rounded mb-4 text-sm">
                {{ message }}
            </p>
        {% endfor %}

        {% if error %}
            <p class="bg-red-50 border border-red-300 text-red-700 px-3 py-2 rounded mb-4 text-sm">
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </p>
        {% endif %}

        <form method="post" class="bg-white border border-gray-200 rounded-lg shadow-sm p-6 space-y-4">
            <div>
                <label class="block font-medium mb-1 text-gray-700 text-sm" for="username">Email</label>
                <input type="email" id="username" name="_username"
                    value="{{ last_username }}"
                    class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm transition"
                    required autofocus>
            </div>

            <div>
                <label class="block font-medium mb-1 text-gray-700 text-sm" for="password">Password</label>
                <input type="password" id="password" name="_password"
                    class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm transition"
                    required>
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button type="submit"
                class="w-full bg-blue-700 hover:bg-blue-800 text-white py-2 rounded-lg transition font-medium text-sm">
                Sign in
            </button>
        </form>

        <p class="text-center mt-3 text-sm">
            <a href="{{ path('forgot_password') }}" class="text-gray-400 hover:text-blue-600 transition">
                Forgot your password?
            </a>
        </p>

        <p class="text-center mt-2 text-sm text-gray-500">
            No account?
            <a href="{{ path('app_register') }}" class="text-blue-700 font-medium hover:underline">Register</a>
        </p>
    </div>
</div>
{% endblock %}
