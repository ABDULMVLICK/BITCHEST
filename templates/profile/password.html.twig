{% extends 'base.html.twig' %}

{% block title %}Change Password - BitChest{% endblock %}

{% block body %}
<nav class="bg-white border-b border-gray-200 px-4 py-3 flex justify-between items-center">
    <span class="font-bold">BitChest</span>
    <a href="{{ path('app_logout') }}" class="text-red-600 hover:underline">Logout</a>
</nav>

<div class="max-w-md mx-auto px-4 py-6">
    <h1 class="text-xl font-bold mb-4">Change Password</h1>

    {% for message in app.flashes('success') %}
        <p class="bg-green-50 border border-green-300 text-green-700 px-3 py-2 rounded mb-3">
            {{ message }}
        </p>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <p class="bg-red-50 border border-red-300 text-red-700 px-3 py-2 rounded mb-3">
            {{ message }}
        </p>
    {% endfor %}

    <form method="post" class="bg-white border border-gray-200 rounded p-6 space-y-4">
        <div>
            <label class="block font-medium mb-1">Current Password</label>
            <input type="password" name="currentPassword" required
                class="w-full border border-gray-300 rounded px-3 py-2">
        </div>
        <div>
            <label class="block font-medium mb-1">New Password</label>
            <input type="password" name="newPassword" required minlength="6"
                class="w-full border border-gray-300 rounded px-3 py-2">
        </div>
        <div>
            <label class="block font-medium mb-1">Confirm New Password</label>
            <input type="password" name="confirmPassword" required
                class="w-full border border-gray-300 rounded px-3 py-2">
        </div>
        <div class="flex gap-3">
            <button type="submit"
                class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700">
                Change Password
            </button>
            <a href="{{ path('profile_edit') }}"
                class="border border-gray-300 px-4 py-2 rounded hover:bg-gray-50">
                Back
            </a>
        </div>
    </form>
</div>
{% endblock %}
