{% extends 'base.html.twig' %}

{% block title %}Register - BitChest{% endblock %}

{% block body %}
<div class="min-h-screen flex">

    {# ── Left panel — branding ── #}
    <div class="hidden md:flex w-2/5 flex-col items-center justify-center bg-blue-900 text-white px-10">
        <img src="{{ asset('images/bitchest_logo.png') }}" alt="BitChest"
            class="h-20 w-20 rounded-full shadow-lg mb-6">
        <h1 class="text-3xl font-bold mb-2 tracking-wide">BitChest</h1>
        <p class="text-blue-300 text-center text-sm leading-relaxed">
            Create your account and start trading crypto<br>
            with a €500 virtual wallet.
        </p>
    </div>

    {# ── Right panel — form ── #}
    <div class="flex-1 flex items-center justify-center bg-gray-50 px-6 py-12">
        <div class="w-full max-w-sm animate-fade-in">

            {# Mobile logo #}
            <div class="md:hidden text-center mb-8">
                <img src="{{ asset('images/bitchest_logo.png') }}" alt="BitChest"
                    class="h-14 w-14 mx-auto rounded-full shadow mb-3">
                <h1 class="text-xl font-bold text-blue-900">BitChest</h1>
            </div>

            <h2 class="text-2xl font-bold text-gray-800 mb-1">Create account</h2>
            <p class="text-gray-400 text-sm mb-6">You'll receive €500 to start trading</p>

            {% for error in errors %}
                <p class="bg-red-50 border border-red-300 text-red-700 px-3 py-2 rounded-lg mb-2 text-sm">
                    {{ error }}
                </p>
            {% endfor %}

            <form method="post" class="space-y-3">
                <div class="grid grid-cols-2 gap-3">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">First Name</label>
                        <input type="text" name="firstName" required
                            class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm bg-white">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Last Name</label>
                        <input type="text" name="lastName" required
                            class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm bg-white">
                    </div>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                    <input type="email" name="email" required
                        class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm bg-white">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Password</label>
                    <input type="password" name="password" required minlength="6"
                        class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm bg-white">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">Confirm Password</label>
                    <input type="password" name="confirmPassword" required
                        class="w-full border border-gray-300 rounded-lg px-3 py-2.5 text-sm bg-white">
                </div>
                <button type="submit" class="btn-primary w-full py-2.5 text-sm mt-1">
                    Create my account
                </button>
            </form>

            <div class="border-t border-gray-200 mt-5 pt-5 text-center text-sm text-gray-500">
                Already have an account?
                <a href="{{ path('app_login') }}" class="text-blue-700 font-medium hover:underline ml-1">Sign in</a>
            </div>
        </div>
    </div>

</div>
{% endblock %}
