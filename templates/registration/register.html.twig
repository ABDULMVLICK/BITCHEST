{% extends 'base.html.twig' %}

{% block title %}Register - BitChest{% endblock %}

{% block body %}
<div class="min-h-screen flex items-center justify-center py-8 px-4 bg-gray-50">
    <div class="w-full max-w-sm animate-fade-in">
        <div class="text-center mb-8">
            <img src="{{ asset('images/bitchest_logo.png') }}" alt="BitChest"
                class="h-16 w-16 mx-auto mb-3 rounded-full shadow">
            <h1 class="text-2xl font-bold text-blue-900">Create an account</h1>
        </div>

        {% for error in errors %}
            <p class="bg-red-50 border border-red-300 text-red-700 px-3 py-2 rounded mb-2">
                {{ error }}
            </p>
        {% endfor %}

        <form method="post" class="bg-white border border-gray-200 rounded-lg shadow-sm p-6 space-y-4">
            <div>
                <label class="block font-medium mb-1">First Name</label>
                <input type="text" name="firstName" required
                    class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm transition">
            </div>
            <div>
                <label class="block font-medium mb-1">Last Name</label>
                <input type="text" name="lastName" required
                    class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm transition">
            </div>
            <div>
                <label class="block font-medium mb-1">Email</label>
                <input type="email" name="email" required
                    class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm transition">
            </div>
            <div>
                <label class="block font-medium mb-1">Password</label>
                <input type="password" name="password" required minlength="6"
                    class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm transition">
            </div>
            <div>
                <label class="block font-medium mb-1">Confirm Password</label>
                <input type="password" name="confirmPassword" required
                    class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm transition">
            </div>
            <button type="submit"
                class="w-full bg-blue-700 hover:bg-blue-800 text-white py-2 rounded-lg transition font-medium text-sm">
                Create account
            </button>
        </form>

        <p class="text-center mt-4 text-gray-600">
            Already have an account?
            <a href="{{ path('app_login') }}" class="text-blue-600 hover:underline">Sign in</a>
        </p>
    </div>
</div>
{% endblock %}
