{% extends 'base.html.twig' %}

{% block title %}Users - Admin{% endblock %}

{% block body %}
<nav style="background:#38618C" class="text-white px-4 py-3 flex flex-wrap justify-between items-center gap-2 shadow-md">
    <div class="flex items-center gap-3">
        <img src="{{ asset('images/bitchest_logo.png') }}" alt="BitChest" class="h-8 w-8 rounded">
        <span class="font-bold text-lg">BitChest <span class="text-blue-300 text-sm font-normal">Admin</span></span>
    </div>
    <div class="flex gap-4">
        <a href="{{ path('admin_prices') }}" class="text-blue-200 hover:text-white transition text-sm">Crypto Prices</a>
        <a href="{{ path('profile_edit') }}" class="text-blue-200 hover:text-white transition text-sm">My Profile</a>
        <a href="{{ path('app_logout') }}" class="bg-red-600 hover:bg-red-700 text-white text-sm px-3 py-1 rounded transition">Logout</a>
    </div>
</nav>

<div class="max-w-4xl mx-auto px-4 py-6">
    <div class="flex justify-between items-center mb-4">
        <h1 class="text-xl font-bold">Users</h1>
        <a href="{{ path('admin_user_new') }}"
            style="background:#38618C" class="text-white px-3 py-1.5 rounded hover:opacity-90 transition">
            + New User
        </a>
    </div>

    {% for message in app.flashes('success') %}
        <p class="bg-green-50 border border-green-300 text-green-700 px-3 py-2 rounded mb-3">
            {{ message|raw }}
        </p>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <p class="bg-red-50 border border-red-300 text-red-700 px-3 py-2 rounded mb-3">
            {{ message }}
        </p>
    {% endfor %}

    <div class="overflow-x-auto rounded-lg border border-gray-200 shadow-sm">
        <table class="w-full bg-white">
            <thead>
                <tr style="background:#38618C" class="text-white text-sm">
                    <th class="text-left px-4 py-3">ID</th>
                    <th class="text-left px-4 py-3">Name</th>
                    <th class="text-left px-4 py-3">Email</th>
                    <th class="text-left px-4 py-3">Role</th>
                    <th class="text-left px-4 py-3">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for user in users %}
                <tr class="border-b border-gray-100 hover:bg-blue-50 transition">
                    <td class="px-4 py-2.5">{{ user.id }}</td>
                    <td class="px-4 py-2.5">{{ user.firstName }} {{ user.lastName }}</td>
                    <td class="px-4 py-2.5">{{ user.email }}</td>
                    <td class="px-4 py-2.5">
                        {% if 'ROLE_ADMIN' in user.roles %}
                            <span style="background:#e0f0ff;color:#38618C" class=" text-xs px-2 py-0.5 rounded font-medium">Admin</span>
                        {% else %}
                            <span class="bg-gray-100 text-gray-600 text-xs px-2 py-0.5 rounded font-medium">Client</span>
                        {% endif %}
                    </td>
                    <td class="px-4 py-2.5">
                        <div class="flex gap-3">
                            <a href="{{ path('admin_user_edit', {id: user.id}) }}"
                                style="background:#38618C" class="text-white text-xs px-2.5 py-1 rounded hover:opacity-90 transition">Edit</a>
                            <form method="post"
                                action="{{ path('admin_user_delete', {id: user.id}) }}"
                                onsubmit="return confirm('Delete this user?');">
                                <input type="hidden" name="_token"
                                    value="{{ csrf_token('delete' ~ user.id) }}">
                                <button class="bg-red-50 hover:bg-red-100 text-red-600 border border-red-200 text-xs px-2.5 py-1 rounded transition">Delete</button>
                            </form>
                        </div>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="5" class="px-3 py-4 text-center text-gray-500">No users.</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
