{% extends 'base.html.twig' %}

{% block title %}Crypto Prices - Admin{% endblock %}

{% block body %}
<nav class="bg-white border-b border-gray-200 px-4 py-3 flex justify-between items-center">
    <span class="font-bold">BitChest Admin</span>
    <div class="flex gap-4">
        <a href="{{ path('admin_index') }}" class="text-gray-600 hover:text-blue-600">Users</a>
        <a href="{{ path('app_logout') }}" class="text-red-600 hover:underline">Logout</a>
    </div>
</nav>

<div class="max-w-md mx-auto px-4 py-6">
    <h1 class="text-xl font-bold mb-4">Current Crypto Prices</h1>

    <table class="w-full border border-gray-200">
        <thead class="bg-gray-100">
            <tr>
                <th class="text-left px-3 py-2 border-b">Cryptocurrency</th>
                <th class="text-right px-3 py-2 border-b">Price (EUR)</th>
            </tr>
        </thead>
        <tbody>
            {% for coin, price in prices %}
            <tr class="border-b hover:bg-gray-50">
                <td class="px-3 py-2">{{ coin }}</td>
                <td class="px-3 py-2 text-right font-mono">
                    €{{ price|number_format(2, '.', ',') }}
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
