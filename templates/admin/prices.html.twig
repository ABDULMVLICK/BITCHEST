{% extends 'base.html.twig' %}

{% block title %}Crypto Prices - Admin{% endblock %}

{% block body %}
<nav class="bg-blue-900 text-white px-4 py-3 flex justify-between items-center shadow-md">
    <div class="flex items-center gap-3">
        <img src="{{ asset('images/bitchest_logo.png') }}" alt="BitChest" class="h-8 w-8 rounded">
        <span class="font-bold text-lg">BitChest <span class="text-blue-300 text-sm font-normal">Admin</span></span>
    </div>
    <div class="flex gap-4">
        <a href="{{ path('admin_index') }}" class="text-blue-200 hover:text-white transition text-sm">Users</a>
        <a href="{{ path('app_logout') }}" class="bg-red-600 hover:bg-red-700 text-white text-sm px-3 py-1 rounded transition">Logout</a>
    </div>
</nav>

<div class="max-w-lg mx-auto px-4 py-6">
    <h1 class="text-xl font-bold mb-4">Current Crypto Prices</h1>

    <div class="rounded-lg border border-gray-200 shadow-sm overflow-hidden">
        <table class="w-full bg-white">
            <thead>
                <tr class="bg-blue-900 text-white text-sm">
                    <th class="text-left px-4 py-3">Cryptocurrency</th>
                    <th class="text-right px-4 py-3">Price (EUR)</th>
                </tr>
            </thead>
            <tbody>
                {% for coin, price in prices %}
                <tr class="border-b border-gray-100 hover:bg-blue-50 transition">
                    <td class="px-4 py-2.5 font-medium">{{ coin }}</td>
                    <td class="px-4 py-2.5 text-right font-mono font-semibold text-blue-900">
                        €{{ price|number_format(2, '.', ',') }}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
