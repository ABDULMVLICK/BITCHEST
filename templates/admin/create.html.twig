{% extends 'base.html.twig' %}

{% block title %}New User - Admin{% endblock %}

{% block body %}
<nav class="bg-blue-900 text-white px-4 py-3 flex justify-between items-center shadow-md">
    <div class="flex items-center gap-3">
        <img src="{{ asset('images/bitchest_logo.png') }}" alt="BitChest" class="h-8 w-8 rounded">
        <span class="font-bold text-lg">BitChest <span class="text-blue-300 text-sm font-normal">Admin</span></span>
    </div>
    <div class="flex gap-3">
        <a href="{{ path('admin_index') }}" class="text-blue-200 hover:text-white transition text-sm">← Back to Users</a>
        <a href="{{ path('app_logout') }}" class="bg-red-600 hover:bg-red-700 text-white text-sm px-3 py-1 rounded transition">Logout</a>
    </div>
</nav>

<div class="max-w-md mx-auto px-4 py-6">
    <h1 class="text-xl font-bold mb-4">New User</h1>

    <p class="bg-yellow-50 border border-yellow-200 text-yellow-800 px-3 py-2 rounded mb-4">
        A temporary password will be generated and shown after creation.
    </p>

    <form method="post" class="bg-white border border-gray-200 rounded p-6 space-y-4">
        <div>
            <label class="block font-medium mb-1">First Name</label>
            <input type="text" name="firstName" required
                class="w-full border border-gray-300 rounded px-3 py-2">
        </div>
        <div>
            <label class="block font-medium mb-1">Last Name</label>
            <input type="text" name="lastName" required
                class="w-full border border-gray-300 rounded px-3 py-2">
        </div>
        <div>
            <label class="block font-medium mb-1">Email</label>
            <input type="email" name="email" required
                class="w-full border border-gray-300 rounded px-3 py-2">
        </div>
        <div>
            <label class="block font-medium mb-1">Role</label>
            <select name="role" class="w-full border border-gray-300 rounded px-3 py-2">
                <option value="ROLE_USER">Client</option>
                <option value="ROLE_ADMIN">Administrator</option>
            </select>
        </div>
        <div class="flex gap-3">
            <button type="submit"
                class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700">
                Create
            </button>
            <a href="{{ path('admin_index') }}"
                class="border border-gray-300 px-4 py-2 rounded hover:bg-gray-50">
                Cancel
            </a>
        </div>
    </form>
</div>
{% endblock %}
